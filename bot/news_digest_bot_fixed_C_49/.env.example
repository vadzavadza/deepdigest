APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

BOT_TOKEN=replace_me
WEBHOOK_BASE_URL=https://example.com
WEBHOOK_SECRET_TOKEN=replace_me

DATABASE_URL=postgresql+psycopg://user:password@postgres:5432/newsbot
REDIS_URL=redis://redis:6379/0

OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
OPENROUTER_SEARCH_MODEL=
OPENROUTER_WEB_SEARCH_MAX_RESULTS=15
NEWS_TOPIC_SOFT_BUDGET_USD=0.07
NEWS_TOPIC_HARD_BUDGET_USD=0.10
NEWS_TOPIC_STOP_MARGIN_USD=0.005
OPENROUTER_RESERVED_LLM_BUDGET_USD=0.025
OPENROUTER_TOPIC_BUDGET_USD=0.10
OPENROUTER_SEARCH_RESULT_COST_USD=0.004
OPENROUTER_SEARCH_CALL_MODEL_RESERVE_USD=0.002
OPENROUTER_LLM_RELEVANCE_ESTIMATED_COST_USD=0.002
OPENROUTER_LLM_SUMMARY_ESTIMATED_COST_USD=0.003
OPENROUTER_LLM_TRANSLATION_ESTIMATED_COST_USD=0.002
OPENROUTER_WEB_SEARCH_RESULTS_PER_CALL=5
OPENROUTER_WEB_SEARCH_MAX_CALLS_PER_TOPIC=3
OPENROUTER_WEB_SEARCH_NORMAL_MAX_CALLS=2
OPENROUTER_WEB_SEARCH_RESCUE_MAX_CALLS=3
OPENROUTER_MIN_QUALITY_CANDIDATES=3
OPENROUTER_ALLOW_PLUGIN_FALLBACK=false
OPENROUTER_DEBUG_REJECTIONS=true
OPENROUTER_MAX_ARTICLE_AGE_HOURS=168
OPENROUTER_REQUIRE_VERIFIED_PUBLISH_DATE=true
OPENROUTER_ALLOW_WEAK_PUBLISH_DATES=false
OPENROUTER_ALLOW_UNDATED_FALLBACK=false
OPENROUTER_FUTURE_SKEW_HOURS=12
ENABLE_OPENROUTER_WEB_SEARCH_SOURCE=true
ENABLE_MOCK_SOURCE=false
ENABLE_TELEGRAM_CHANNEL_SOURCE=false
ENABLE_RSS_SOURCE=false

DEFAULT_TIMEZONE=Asia/Tbilisi
DEFAULT_OUTPUT_LANGUAGE=en
STORY_MEMORY_DAYS=7
MAX_ARTICLES_PER_PROVIDER=100
MAX_STORIES_PER_POST=5
LLM_RELEVANCE_MAX_CHECKS_PER_TOPIC=8
LLM_SKIP_RELEVANCE_FOR_NATIVE_JUDGED_CANDIDATES=true
LLM_NATIVE_RELEVANCE_MIN_TOPIC_MATCH=0.70
PUBLISH_EMPTY_DIGEST=false

SCHEDULER_REFRESH_SECONDS=10
SCHEDULER_JOB_MISFIRE_GRACE_SECONDS=300

# v5.2 quality/recall balance
# Keeps verified publish dates as default, but allows at most one high-confidence
# search-snippet fallback when strict freshness returns too little.
OPENROUTER_ALLOW_SEARCH_SNIPPET_FALLBACK=true
OPENROUTER_SEARCH_SNIPPET_FALLBACK_MIN_DIRECTNESS=12
OPENROUTER_SEARCH_SNIPPET_FALLBACK_MIN_CONFIDENCE=2
OPENROUTER_MAX_WEAK_FRESHNESS_ITEMS_PER_DIGEST=1

# v5.3 single-run adaptive search
OPENROUTER_ADAPTIVE_TARGET_CANDIDATES=3
OPENROUTER_MIN_SEARCH_PASSES=2
IMMEDIATE_REPEAT_GUARD_MINUTES=15

# v6 universal search core
OPENROUTER_VERIFIED_HARD_MAX_ARTICLE_AGE_HOURS=720
OPENROUTER_FOLLOWUP_HARD_MAX_ARTICLE_AGE_HOURS=72

# v6.3 evaluation/replay: save raw search candidates + decisions to ./debug_runs
SEARCH_DEBUG_DUMP_ENABLED=false
SEARCH_DEBUG_DUMP_DIR=debug_runs
SEARCH_EVAL_FIXTURE_DIR=eval_fixtures

# v7.1 OpenRouter-native usage
# Use OpenRouter web_search as a structured news agent, not only as a raw URL provider.
OPENROUTER_NATIVE_NEWS_AGENT_ENABLED=true
OPENROUTER_NATIVE_JUDGE_MIN_TOPIC_MATCH=0.62
OPENROUTER_NATIVE_JUDGE_MAX_CANDIDATES=8
OPENROUTER_NATIVE_REJECT_WEAK_SOURCES=true
# For testing, debug dumps are strongly recommended. app_debug=true also enables dumps in v7.1.
SEARCH_DEBUG_DUMP_ENABLED=true
